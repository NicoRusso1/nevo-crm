# ──────────────────────────────────────────────
# neVo CRM — Monorepo root .gitignore
# (each workspace also has its own .gitignore)
# ──────────────────────────────────────────────

# Dependencies (root-level, just in case)
node_modules/

# Environment
.env
.env.local
.env.*.local
!.env.example

# Build / cache
dist/
build/
.cache/
*.tsbuildinfo

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Coverage
coverage/
.nyc_output/

# IDE / Editors
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
desktop.ini
