// ─────────────────────────────────────────────────────────────────────────────
// neVo CRM — Prisma Schema
// Database: MySQL
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  MANAGER
  SALES_REP
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL_SENT
  NEGOTIATION
  WON
  LOST
}

enum ActivityType {
  CALL
  EMAIL
  MEETING
  TASK
}

enum DealStage {
  LEAD
  QUALIFIED
  PROPOSAL
  NEGOTIATION
  WON
  LOST
}

// ─────────────────────────────────────────────────────────────────────────────
// Models
// ─────────────────────────────────────────────────────────────────────────────

/// Application user. Authenticates and owns CRM records.
model User {
  id        String   @id @default(cuid())
  name      String   @db.VarChar(120)
  email     String   @unique @db.VarChar(191)
  password  String   @db.VarChar(255) // bcrypt hash
  avatar    String?  @db.VarChar(500)
  role      Role     @default(SALES_REP)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ── Relations ───────────────────────────────────────────────────────────
  assignedLeads Lead[]         @relation("LeadAssignee")
  ownedDeals    Deal[]         @relation("DealOwner")
  activities    Activity[]
  notifications Notification[]

  @@index([role])
}

/// Top-of-funnel prospect. May become a Client once converted.
model Lead {
  id      String     @id @default(cuid())
  name    String     @db.VarChar(120)
  company String?    @db.VarChar(160)
  email   String     @db.VarChar(191)
  phone   String?    @db.VarChar(40)
  source  String?    @db.VarChar(80) // e.g. "Website", "Referral", "Cold Call"
  status  LeadStatus @default(NEW)
  value   Decimal?   @db.Decimal(12, 2) // estimated deal value
  notes   String?    @db.Text

  assignedToId String?
  assignedTo   User?   @relation("LeadAssignee", fields: [assignedToId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ── Relations ───────────────────────────────────────────────────────────
  activities Activity[]

  @@index([status])
  @@index([assignedToId])
  @@index([email])
  @@index([createdAt])
}

/// A converted, contractable account. Source of truth for billable relationships.
model Client {
  id          String   @id @default(cuid())
  companyName String   @db.VarChar(160)
  contactName String   @db.VarChar(120)
  email       String   @unique @db.VarChar(191)
  phone       String?  @db.VarChar(40)
  industry    String?  @db.VarChar(80)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // ── Relations ───────────────────────────────────────────────────────────
  deals Deal[]

  @@index([industry])
  @@index([companyName])
}

/// Sales opportunity attached to a Client and owned by a User.
model Deal {
  id                String    @id @default(cuid())
  title             String    @db.VarChar(160)
  value             Decimal   @db.Decimal(12, 2)
  probability       Int       @default(0) // 0–100 (validated at app layer)
  expectedCloseDate DateTime?
  stage             DealStage @default(LEAD)

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  ownerId String
  owner   User   @relation("DealOwner", fields: [ownerId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ── Relations ───────────────────────────────────────────────────────────
  activities Activity[]

  @@index([stage])
  @@index([clientId])
  @@index([ownerId])
  @@index([expectedCloseDate])
}

/// Anything a user does (or must do): calls, emails, meetings, tasks.
/// Optionally tied to a Lead and/or a Deal — at least one is typical but not
/// enforced at the DB level (a free-standing personal task is also valid).
model Activity {
  id          String       @id @default(cuid())
  type        ActivityType
  description String       @db.Text
  dueDate     DateTime?
  completed   Boolean      @default(false)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  leadId String?
  lead   Lead?   @relation(fields: [leadId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  dealId String?
  deal   Deal?   @relation(fields: [dealId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([leadId])
  @@index([dealId])
  @@index([dueDate])
  @@index([completed])
  @@index([type])
}

/// In-app notification for a user (e.g. "Deal X moved to NEGOTIATION").
model Notification {
  id      String  @id @default(cuid())
  title   String  @db.VarChar(200)
  message String  @db.Text
  read    Boolean @default(false)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([read])
  @@index([createdAt])
  @@index([userId, read]) // covers "unread notifications for user X" queries
}
